<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <LangVersion>latest</LangVersion>
    <AssemblyName>MainGameObjectComposer</AssemblyName>
    <RootNamespace>MainGameObjectComposer</RootNamespace>
