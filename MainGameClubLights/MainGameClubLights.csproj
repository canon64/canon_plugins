    </Reference>
    <Reference Include="VRGIN_OpenXR" Private="false">
      <HintPath>$(BepInExDir)\plugins\KKS_VR\VRGIN_OpenXR.dll</HintPath>
    </Reference>
    <Reference Include="Unity.XR.OpenVR" Private="false">
      <HintPath>$(BepInExDir)\plugins\KKS_VR\Unity.XR.OpenVR.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="_ilspy_tmp\**\*.cs" />
    <Compile Remove="_ilspy_tmp2\**\*.cs" />
  </ItemGroup>
</Project>
