    </Reference>
    <Reference Include="UnityEngine.TextRenderingModule">
      <HintPath>$(KKSDir)\KoikatsuSunshine_Data\Managed\UnityEngine.TextRenderingModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.PhysicsModule">
      <HintPath>$(KKSDir)\KoikatsuSunshine_Data\Managed\UnityEngine.PhysicsModule.dll</HintPath>
    </Reference>
    <Reference Include="MainGameBlankMapAdd" Private="false">
      <HintPath Condition="Exists('$(BepInExDir)\plugins\MainGameBlankMapAdd\MainGameBlankMapAdd.dll')">$(BepInExDir)\plugins\MainGameBlankMapAdd\MainGameBlankMapAdd.dll</HintPath>
      <HintPath Condition="Exists('$(BepInExDir)\plugins\canon_plugins\MainGameBlankMapAdd\MainGameBlankMapAdd.dll')">$(BepInExDir)\plugins\canon_plugins\MainGameBlankMapAdd\MainGameBlankMapAdd.dll</HintPath>
    </Reference>
    <Reference Include="MainGameBeatSyncSpeed" Private="false">
      <HintPath Condition="Exists('$(BepInExDir)\plugins\MainGameBeatSyncSpeed\MainGameBeatSyncSpeed.dll')">$(BepInExDir)\plugins\MainGameBeatSyncSpeed\MainGameBeatSyncSpeed.dll</HintPath>
      <HintPath Condition="Exists('$(BepInExDir)\plugins\canon_plugins\MainGameBeatSyncSpeed\MainGameBeatSyncSpeed.dll')">$(BepInExDir)\plugins\canon_plugins\MainGameBeatSyncSpeed\MainGameBeatSyncSpeed.dll</HintPath>
    </Reference>
    <Reference Include="MainGameTransformGizmo" Private="false">
      <HintPath Condition="Exists('$(BepInExDir)\plugins\MainGameTransformGizmo\MainGameTransformGizmo.dll')">$(BepInExDir)\plugins\MainGameTransformGizmo\MainGameTransformGizmo.dll</HintPath>
      <HintPath Condition="Exists('$(BepInExDir)\plugins\canon_plugins\MainGameTransformGizmo\MainGameTransformGizmo.dll')">$(BepInExDir)\plugins\canon_plugins\MainGameTransformGizmo\MainGameTransformGizmo.dll</HintPath>
    </Reference>
    <Reference Include="MainGameUiInputCapture" Private="false">
      <HintPath Condition="Exists('$(BepInExDir)\plugins\MainGameUiInputCapture\MainGameUiInputCapture.dll')">$(BepInExDir)\plugins\MainGameUiInputCapture\MainGameUiInputCapture.dll</HintPath>
